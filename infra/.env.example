# Copy this file to .env and adjust values as needed

# --- Logging ---
# LOG_LEVEL: debug | info | warn | error (default: info)
# LOG_FORMAT: json | text (default: json)
LOG_LEVEL=info
LOG_FORMAT=json

# --- Postgres ---
POSTGRES_USER=dictai
POSTGRES_PASSWORD=dictai_secret
POSTGRES_DB=dictai
POSTGRES_PORT=5432
POSTGRES_HOST=postgres
MIGRATION_VERSION=1

# --- Nats ---
NATS_URL=nats://nats:4222
NATS_SUBJECT=audio.uploaded
NATS_TRANSCRIBED_SUBJECT=audio.transcribed
NATS_DIARIZED_SUBJECT=audio.diarized

# --- Auth ---
AUTH_SERVICE_JWT_SECRET=change_me_in_production

# --- MINIO ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# --- Gateway ---
# Internal port of the gateway container (exposed as 8000 on the host)
GATEWAY_SERVICE_PORT=8080
GATEWAY_WORKSPACE_SERVICE_URL=http://workspace-service:8080
GATEWAY_MEETING_SERVICE_URL=http://workspace-service:8080
GATEWAY_AUDIO_INGEST_SERVICE_URL=http://ingest-service:8080
GATEWAY_VOICE_PROFILE_SERVICE_URL=http://voice-profile-service:8080
GATEWAY_AUTH_SERVICE_URL=http://auth-service:8080
GATEWAY_RATE_LIMIT=100
GATEWAY_RATE_LIMIT_RPS=10

# --- Workspace Service ---
# Internal port the service listens on (also exposed on the host via docker-compose)
WORKSPACE_SERVICE_PORT=8080

# --- Audio Ingest Service ---
# Internal ports (host: 8081→HTTP, 8082→gRPC)
AUDIO_INGEST_SERVICE_PORT=8080
AUDIO_INGEST_SERVICE_GRPC_PORT=8000
AUDIO_INGEST_WORKSPACE_SERVICE_URL=http://workspace-service:8080
AUDIO_INGEST_MINIO_ENDPOINT=minio:9000
AUDIO_INGEST_MINIO_BUCKET=audio
# Used by transcription-service and transcript-builder-service (no http://)
INGEST_SERVICE_GRPC_URL=audio-ingest-service:8000

# --- Voice Profile Service ---
VOICE_PROFILE_SERVICE_PORT=8080
PY_SPEACH_TO_VECTOR_SERVICE_ENDPOINT=http://speaker-recognition-service:8000

# --- Speaker Recognition Service ---
SPEAKER_RECOGNITION_PORT=8000
WORKSPACE_SERVICE_URL=http://workspace-service:8080
WORKSPACE_PARTICIPANTS_PATH=/workspaces/{workspace_id}/participants
VOICE_PROFILE_SERVICE_URL=http://voice-profile-service:8080
VOICE_PROFILE_GRPC_ADDR=
VOICE_PROFILE_PATH=/voice-profiles/profiles/{participant_id}
EMBED_THRESHOLD=0.7

# --- HuggingFace ---
# Required for pyannote/embedding model download
# Accept terms at: https://huggingface.co/pyannote/embedding
HUGGINGFACE_TOKEN=

# --- WhisperX Service ---
# WHISPERX_MODEL is overridden to "base" in docker-compose for faster startup
WHISPERX_MODEL=medium
WHISPERX_DEVICE=cpu
WHISPERX_COMPUTE_TYPE=float32
WHISPERX_BATCH_SIZE=16
WHISPERX_HOST=0.0.0.0
WHISPERX_PORT=8000
WHISPERX_MAX_FILE_SIZE=1048576000
WHISPERX_CHUNK_SIZE=1048576
WHISPERX_ENDPOINT=http://whisper-server:8000

# --- Results Service ---
RESULTS_SERVICE_PORT=8080
RESULTS_SERVICE_MINIO_ENDPOINT=minio:9000
RESULTS_SERVICE_MINIO_BUCKET=results
RESULTS_SERVICE_URL=http://results-service:8080

# --- Summarization Service ---
SUMMARIZATION_PUBLISH_SUBJECT=audio.summarized
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://gate.trinity.tg/aurora/v1/messages
ANTHROPIC_MODEL=claude-opus-4-7

# --- Notification Service ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=secret
SMTP_FROM=notifications@example.com
