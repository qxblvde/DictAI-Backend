{
  "title": "System Overview",
  "uid": "system-overview",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "gauge", "title": "CPU Usage %",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent",
        "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":70},{"color":"red","value":90}] }
      }},
      "targets": [{ "datasource": "Prometheus",
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)" }]
    },
    {
      "id": 2, "type": "gauge", "title": "RAM Usage %",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent",
        "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":75},{"color":"red","value":90}] }
      }},
      "targets": [{ "datasource": "Prometheus",
        "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100" }]
    },
    {
      "id": 3, "type": "gauge", "title": "Disk Usage %",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent",
        "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":75},{"color":"red","value":90}] }
      }},
      "targets": [{ "datasource": "Prometheus",
        "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100" }]
    },
    {
      "id": 4, "type": "stat", "title": "Running Containers",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "short",
        "thresholds": { "steps": [{"color":"red","value":0},{"color":"green","value":1}] }
      }},
      "targets": [{ "datasource": "Prometheus",
        "expr": "count(container_last_seen{name!=\"\",name!~\".*cadvisor.*|.*prometheus.*|.*grafana.*\"})" }]
    },
    {
      "id": 5, "type": "timeseries", "title": "CPU Usage Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "percent" }},
      "targets": [{ "datasource": "Prometheus",
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
        "legendFormat": "CPU %" }]
    },
    {
      "id": 6, "type": "timeseries", "title": "Memory Usage Over Time",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }},
      "targets": [
        { "datasource": "Prometheus", "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used" },
        { "datasource": "Prometheus", "expr": "node_memory_MemTotal_bytes", "legendFormat": "Total" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Network I/O",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" }},
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*\"}[2m])", "legendFormat": "RX {{device}}" },
        { "datasource": "Prometheus", "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*\"}[2m])", "legendFormat": "TX {{device}}" }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Disk I/O",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" }},
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(node_disk_read_bytes_total[2m])", "legendFormat": "Read {{device}}" },
        { "datasource": "Prometheus", "expr": "rate(node_disk_written_bytes_total[2m])", "legendFormat": "Write {{device}}" }
      ]
    },
    {
      "id": 9, "type": "timeseries", "title": "Container CPU Usage",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "percent" }},
      "targets": [{ "datasource": "Prometheus",
        "expr": "rate(container_cpu_usage_seconds_total{name!=\"\",name!~\".*cadvisor.*|.*prometheus.*|.*grafana.*|.*node-exporter.*\"}[2m]) * 100",
        "legendFormat": "{{name}}" }]
    },
    {
      "id": 10, "type": "timeseries", "title": "Container Memory Usage",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }},
      "targets": [{ "datasource": "Prometheus",
        "expr": "container_memory_usage_bytes{name!=\"\",name!~\".*cadvisor.*|.*prometheus.*|.*grafana.*|.*node-exporter.*\"}",
        "legendFormat": "{{name}}" }]
    }
  ]
}
